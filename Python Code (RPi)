def read_sensor_data():
    """Read sensor data from the Arduino Mega."""
    try:
        raw_line = ser.readline().decode().strip()
        logging.debug(f"Raw data received from Arduino Mega: {raw_line}")
        
        if raw_line.startswith("SENSOR_DATA:"):
            parts = raw_line.split(":")[1].split(",")
            logging.debug(f"Parsed parts: {parts}")
            
            if len(parts) == 16:
                try:
                    return {
                        "water_temperature": float(parts[0]) if parts[0] != 'nan' else None,
                        "tds_raw_adc": int(parts[1]) if parts[1] != 'nan' else None,
                        "ph_raw_adc": int(parts[2]) if parts[2] != 'nan' else None,
                        "dht1_temp_c": float(parts[3]) if parts[3] != 'nan' else None,
                        "dht1_humidity": float(parts[4]) if parts[4] != 'nan' else None,
                        "dht2_temp_c": float(parts[5]) if parts[5] != 'nan' else None,
                        "dht2_humidity": float(parts[6]) if parts[6] != 'nan' else None,
                        "dht3_temp_c": float(parts[7]) if parts[7] != 'nan' else None,
                        "dht3_humidity": float(parts[8]) if parts[8] != 'nan' else None,
                        "dht4_temp_c": float(parts[9]) if parts[9] != 'nan' else None,
                        "dht4_humidity": float(parts[10]) if parts[10] != 'nan' else None,
                        "dht5_temp_c": float(parts[11]) if parts[11] != 'nan' else None,
                        "dht5_humidity": float(parts[12]) if parts[12] != 'nan' else None,
                        "distance_cm": float(parts[13]) if parts[13] != 'nan' else None,
                        "current_reading": float(parts[14]) if parts[14] != 'nan' else None,
                        "voltage_reading": float(parts[15]) if parts[15] != 'nan' else None
                    }
                except ValueError as e:
                    logging.error(f"Error parsing sensor data: {e}")
            else:
                logging.warning(f"Incomplete data received. Expected 16 values, got {len(parts)}.")
        else:
            logging.warning(f"Unexpected data format: {raw_line}")
    except Exception as e:
        logging.error(f"Error reading sensor data: {e}")
    return None

def calculate_tds(tds_raw_adc, water_temp):
    """Calculate TDS value from raw ADC reading and water temperature."""
    if tds_raw_adc is None or water_temp is None:
        return None
        
    average_voltage = tds_raw_adc * VREF / ADC_RESOLUTION
    if average_voltage < MIN_VOLTAGE_THRESHOLD:
        logging.warning("Probes not submerged! Invalid TDS readings.")
        return None
        
    compensation_coefficient = 1.0 + 0.018 * (water_temp - 25.0)
    compensation_voltage = average_voltage / compensation_coefficient
    tds = (TDS_A * compensation_voltage**3 -
           TDS_B * compensation_voltage**2 +
           TDS_C * compensation_voltage) * TDS_D
    return tds

def calculate_ph(ph_raw_adc):
    """Calculate pH value from raw ADC reading."""
    if ph_raw_adc is None:
        return None
        
    voltage = ph_raw_adc * VREF / ADC_RESOLUTION
    if voltage < 0.03 or voltage > 3.2:
        logging.warning("Invalid voltage reading from pH sensor!")
        return None
        
    TOLERANCE = 1e-6
    if PH_VOLTAGE_AT_PH_7 - TOLERANCE <= voltage <= PH_VOLTAGE_AT_PH_4 + TOLERANCE:
        ph = 4.0 + (7.0 - 4.0) * (voltage - PH_VOLTAGE_AT_PH_4) / (PH_VOLTAGE_AT_PH_7 - PH_VOLTAGE_AT_PH_4)
    elif PH_VOLTAGE_AT_PH_10 - TOLERANCE <= voltage < PH_VOLTAGE_AT_PH_7 + TOLERANCE:
        ph = 7.0 + (10.0 - 7.0) * (voltage - PH_VOLTAGE_AT_PH_7) / (PH_VOLTAGE_AT_PH_10 - PH_VOLTAGE_AT_PH_7)
    else:
        return None
        
    return max(0.0, min(ph, 14.0))

def average_dht_readings(sensor_data):
    """Average the temperature and humidity readings from the five DHT11 sensors."""
    temps = [
        sensor_data["dht1_temp_c"],
        sensor_data["dht2_temp_c"],
        sensor_data["dht3_temp_c"],
        sensor_data["dht4_temp_c"],
        sensor_data["dht5_temp_c"]
    ]
    humidities = [
        sensor_data["dht1_humidity"],
        sensor_data["dht2_humidity"],
        sensor_data["dht4_humidity"],
        sensor_data["dht5_humidity"]
    ]
    
    temps = [temp for temp in temps if temp is not None]
    humidities = [humidity for humidity in humidities if humidity is not None]
    
    avg_temp = statistics.mean(temps) if temps else None
    avg_humidity = statistics.mean(humidities) if humidities else None
    
    return avg_temp, avg_humidity

def distance_to_percentage(distance_cm):
    """Convert distance measurement to water level percentage."""
    if distance_cm is None:
        return None
    if distance_cm >= TANK_EMPTY_LEVEL:
        return 0
    if distance_cm <= TANK_FULL_LEVEL:
        return 100
    # Linear interpolation
    percent = 100 * (TANK_EMPTY_LEVEL - distance_cm) / (TANK_EMPTY_LEVEL - TANK_FULL_LEVEL)
    return round(percent, 1)

