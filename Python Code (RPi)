#------------------------------------------------------------------------------
# MQTT RPC Handler for LED Tower Control
#------------------------------------------------------------------------------
def on_connect(client, userdata, flags, rc):
    client.subscribe('v1/devices/me/rpc/request/+')

def on_message(client, userdata, msg):
    global relay22_state, relay23_state, relay28_state, relay29_state

    try:
        data = json.loads(msg.payload.decode())
        method = data.get('method')
        params = data.get('params')
        request_id = msg.topic.split('/')[-1]

        # LED Tower 1 (Relay 22)
        if method == "setRelay22" or method == "setValue22":
            relay22_state = bool(params)
            color = 65535 if relay22_state else 0
            control_led_strip_with_timer(relay22_state, 22, color)
            client.publish(f'v1/devices/me/rpc/response/{request_id}', json.dumps(relay22_state))
        elif method == "getRelay22" or method == "getvalue22":
            client.publish(f'v1/devices/me/rpc/response/{request_id}', json.dumps(relay22_state))

        # LED Tower 2 (Relay 23)
        elif method == "setRelay23" or method == "setValue23":
            relay23_state = bool(params)
            color = 65535 if relay23_state else 0
            control_led_strip_with_timer(relay23_state, 23, color)
            client.publish(f'v1/devices/me/rpc/response/{request_id}', json.dumps(relay23_state))
        elif method == "getRelay23" or method == "getvalue23":
            client.publish(f'v1/devices/me/rpc/response/{request_id}', json.dumps(relay23_state))
        
        #Motor Tower 1 (Relay 28)
        elif method == "setRelay28" or method == "setValue28":
            relay28_state = bool(params)
            send_command(f"RELAY:28,{1 if relay28_state else 0}")
            client.publish(f'v1/devices/me/rpc/response/{request_id}', json.dumps(relay28_state))
        elif method == "getRelay28" or method == "getvalue28":
            relay28_state = ser.readline().decode().strip()
            client.publish(f'v1/devices/me/rpc/response/{request_id}', json.dumps(relay28_state))

        #Motor Tower 2 (Relay 29)
        elif method == "setRelay29" or method == "setValue29":
            relay29_state = bool(params)
            send_command(f"RELAY:29,{1 if relay29_state else 0}")  # <-- Add colon here
            client.publish(f'v1/devices/me/rpc/response/{request_id}', json.dumps(relay29_state))
        elif method == "getRelay29" or method == "getvalue29":
            relay29_state = ser.readline().decode().strip()
            client.publish(f'v1/devices/me/rpc/response/{request_id}', json.dumps(relay29_state))

    except Exception as e:
        logging.error(f"Error handling RPC: {e}")

def start_mqtt_listener():
    client = mqtt.Client()
    client.username_pw_set(ACCESS_TOKEN)
    client.on_connect = on_connect
    client.on_message = on_message
    client.connect(THINGSBOARD_HOST, 1883, 60)
    client.loop_forever()

