def send_command(command):
    """Send a command to the Arduino Mega."""
    if manual_override or emergency_stop:
        logging.warning(f"Command {command} not sent due to override/emergency")
        return
        
    try:
        ser.write((command + "\n").encode())
        logging.info(f"Command sent: {command}")
    except Exception as e:
        logging.error(f"Failed to send command: {e}")

def send_to_thingsboard(data):
    """Send sensor data to ThingsBoard using the HTTP API."""
    try:
        url = THINGSBOARD_URL.format(ACCESS_TOKEN=ACCESS_TOKEN)
        response = requests.post(url, json=data)
        if response.status_code == 200:
            logging.debug(f"Data sent to ThingsBoard: {data}")
        else:
            logging.error(f"Failed to send data. Status Code: {response.status_code}")
    except Exception as e:
        logging.error(f"Error sending data to ThingsBoard: {e}")

def should_led_strip_be_on(switch_state):
    now = datetime.datetime.now()
    hour = now.hour
    # From 21:00 to 4:59, always OFF
    if hour >= 21 or hour < 5:
        return False
    # From 5:00 to 20:59, follow the switch
    else:
        return switch_state

def control_led_strip_with_timer(switch_state, relay_pin, color=65535):
    """Control the relay and color for the LED strip based on timer and switch state."""
    if should_led_strip_be_on(switch_state):
        send_command(f"RELAY:{relay_pin},1")  # Turn ON relay
        send_command(f"LED_STRIP:{color}")    # Set color (adjust command as needed)
    else:
        send_command(f"RELAY:{relay_pin},0")  # Turn OFF relay

def misting_pump_control(current_time):
    """Control the misting pump with improved timing and safety checks."""
    global last_misting_time, misting_pump_active, last_misting_end_time
    
    if (emergency_stop or manual_override or tank_refill_active or 
        (current_time - refill_complete_time < REFILL_SETTLING_TIME * 1000)):
        if misting_pump_active:
            misting_pump_active = False
            send_command("RELAY:35,0")
            logging.info("Misting pump forced OFF due to system state")
        return

    if not misting_pump_active:
        # Check if enough time has passed since last cycle
        time_since_last = current_time - last_misting_end_time
        if (time_since_last >= MISTING_INTERVAL * 1000 and 
            time_since_last >= MIN_MISTING_CYCLE_GAP * 1000):
            misting_pump_active = True
            last_misting_time = current_time
            send_command("RELAY:35,1")
            logging.info("Misting pump activated")
    else:
        if current_time - last_misting_time >= MISTING_DURATION * 1000:
            misting_pump_active = False
            last_misting_end_time = current_time
            send_command("RELAY:35,0")
            logging.info("Misting pump deactivated after duration")

def tank_reservoir_refill_control(distance_cm, current_time, tds=None, ph=None):
    global tank_refill_active, nutrient_pump_active, nutrient_pump_start_time
    global mixing_pump_active, previous_tank_level
    global refill_complete_time, emergency_stop, distance_sensor_fail_time
    global nutrients_added_this_cycle, tank_was_low_or_empty
    global tds_baseline, ph_baseline

    # Handle distance sensor failure
    if distance_cm is None:
        if distance_sensor_fail_time is None:
            distance_sensor_fail_time = current_time
            logging.warning("Distance sensor failed - starting fail timer")
        elif (current_time - distance_sensor_fail_time > MAX_DISTANCE_SENSOR_FAIL_TIME * 1000):
            emergency_stop = True
            logging.error("EMERGENCY STOP: Distance sensor failed for too long")
        return "Unknown"
    else:
        distance_sensor_fail_time = None
        if emergency_stop:
            emergency_stop = False
            logging.info("Emergency stop cleared - distance sensor working")

    # --- Water Level Determination (non-overlapping ranges) ---
    if distance_cm < TANK_OVERLOW_LEVEL:
        tank_level = "Overflow"
    elif TANK_OVERLOW_LEVEL <= distance_cm < TANK_FULL_LEVEL:
        tank_level = "Full"
    elif TANK_FULL_LEVEL <= distance_cm < TANK_HALF_LEVEL:
        tank_level = "Half"
    elif TANK_HALF_LEVEL <= distance_cm < TANK_LOW_LEVEL:
        tank_level = "Half"
    elif TANK_LOW_LEVEL <= distance_cm <= TANK_EMPTY_LEVEL:
        tank_level = "Low"
    elif distance_cm <= TANK_EMPTY_LEVEL:
        tank_level = "Empty"
    else:
        tank_level = "Unknown"

    # --- Track if tank has reached Low or Empty since last Full ---
    if tank_level in ("Low", "Empty"):
        tank_was_low_or_empty = True

    if tank_level == "Full" and previous_tank_level != "Full":
        # Set baselines for TDS and pH right before nutrients are added
        if tank_was_low_or_empty and not nutrients_added_this_cycle:
            tds_baseline = tds if tds is not None else 0
            ph_baseline = ph if ph is not None else 0
            send_command("RELAY:33,1")  # Start mixing pump
            mixing_pump_active = True
            nutrient_pump_active = True
            nutrient_pump_start_time = current_time
            send_command("RELAY:30,1")  # Start nutrient A
            send_command("RELAY:31,1")  # Start nutrient B
            nutrients_added_this_cycle = True
            logging.info(f"Mixing and nutrient addition started (baseline: TDS={tds_baseline}, pH={ph_baseline})")
        tank_was_low_or_empty = False  # Reset for next cycle

    # --- Reset nutrients_added flag when level drops below Full ---
    if tank_level != "Full" and previous_tank_level == "Full":
        nutrients_added_this_cycle = False

    # --- Main control logic if level changed or nutrient pump is active ---
    if tank_level != previous_tank_level or nutrient_pump_active:
        logging.info(f"Tank level: {tank_level} (Distance: {distance_cm} cm)")

        # Handle overflow
        if tank_level == "Overflow":
            tank_refill_active = False
            nutrient_pump_active = False
            mixing_pump_active = False
            send_command("RELAY:32,0")  # Stop refill
            send_command("RELAY:33,0")  # Stop mixing
            send_command("RELAY:30,0")  # Stop nutrient A
            send_command("RELAY:31,0")  # Stop nutrient B
            emergency_stop = True
            logging.warning("EMERGENCY STOP: Tank overflow detected!")

        # Handle full (stop refill only)
        elif tank_level == "Full":
            if tank_refill_active:
                tank_refill_active = False
                refill_complete_time = current_time
                send_command("RELAY:32,0")
                logging.info("Tank refill stopped (reached full)")

        # Handle low/empty (start refill, stop mixing/nutrients)
        elif tank_level in ("Low", "Empty"):
            if not tank_refill_active:
                tank_refill_active = True
                send_command("RELAY:32,1")
                logging.info("Tank refill started (low/empty level)")
            if mixing_pump_active:
                send_command("RELAY:33,0")
                mixing_pump_active = False
                logging.info("Mixing pump stopped (low/empty level)")
            if nutrient_pump_active:
                send_command("RELAY:30,0")
                send_command("RELAY:31,0")
                nutrient_pump_active = False

        # Optionally handle "Half" level here if needed

    # --- Nutrient pump timeout (mixing pump continues running) ---
    if nutrient_pump_active and (current_time - nutrient_pump_start_time >= NUTRIENT_PUMP_DURATION * 1000):
        nutrient_pump_active = False
        send_command("RELAY:30,0")
        send_command("RELAY:31,0")
        logging.info("Nutrient addition completed (mixing continues)")

    previous_tank_level = tank_level
    return tank_level

def thermal_control():
    """Control the thermal system based on temperature readings."""
    if manual_override or emergency_stop:
        return
        
    # Read temperature from sensors
    sensor_data = read_sensor_data()
    if not sensor_data:
        return
    
    avg_temp, _ = average_dht_readings(sensor_data)
    
    if avg_temp is None:
        return
    
    # Control logic for heating/cooling
    if avg_temp > TEMP_MIN:
        send_command("RELAY:37,1")  # Turn on heating
        logging.info("Heating turned ON (Low Temperature)")
    elif avg_temp < TEMP_MAX:
        send_command("RELAY:37,0")  # Turn off heating
        logging.info("Heating turned OFF (High Temperature)")

def control_fans(avg_humidity):
    """Control intake and exhaust fans based on average humidity."""
    if avg_humidity is None or manual_override or emergency_stop:
        return

    humidity_avg = (HUMIDITY_MAX + HUMIDITY_MIN) / 2

    if avg_humidity > HUMIDITY_MAX:
        send_command("RELAY:27,1")  # Turn on INTAKE_FANS_PIN
        send_command("RELAY:26,1")  # Turn on EXHAUST_FANS_PIN
        logging.info("Fans turned ON (High Humidity)")
    elif avg_humidity == humidity_avg:
        send_command("RELAY:27,0")  # Turn off INTAKE_FANS_PIN
        send_command("RELAY:26,0")  # Turn off EXHAUST_FANS_PIN
        logging.info("Fans turned OFF (Humidity at average)")
    elif avg_humidity > HUMIDITY_MIN:
        send_command("RELAY:27,0")  # Turn off INTAKE_FANS_PIN
        send_command("RELAY:26,0")  # Turn off EXHAUST_FANS_PIN
        logging.info("Fans turned OFF (Low Humidity)")

#------------------------------------------------------------------------------
# Main Function
#------------------------------------------------------------------------------        
def main():
    """Main control loop for the hydroponic system."""
    global tds_baseline, ph_baseline
    
    # Start MQTT listener in a separate thread
    mqtt_thread = threading.Thread(target=start_mqtt_listener, daemon=True)
    mqtt_thread.start()
    
    # Start Flask web server in a separate thread
    flask_thread = threading.Thread(target=run_flask_app, daemon=True)
    flask_thread.start()
    
    logging.info("Hydroponic system controller started")
    logging.info(f"Web interface available at http://0.0.0.0:5000")
    
    while True:
        current_time = time.time() * 1000  # Current time in milliseconds
        
        # Read sensor data
        sensor_data = read_sensor_data()
        if not sensor_data:
            time.sleep(1)
            continue
        
        misting_pump_control(current_time)
        thermal_control()
        avg_temp, avg_humidity = average_dht_readings(sensor_data)
        control_fans(avg_humidity)

        # Calculate derived values
        water_temp = sensor_data["water_temperature"]
        tds = calculate_tds(sensor_data["tds_raw_adc"], water_temp)
        ph = calculate_ph(sensor_data["ph_raw_adc"])
        water_level_percent = distance_to_percentage(sensor_data["distance_cm"])

         # Tank and pump control (updates tank_refill_active)
        tank_level = tank_reservoir_refill_control(sensor_data["distance_cm"], current_time, tds, ph)
        
        # Calculate net TDS and pH (after nutrients)
        net_tds = tds - tds_baseline if tds is not None and tds_baseline is not None else None
        net_ph = ph - ph_baseline if ph is not None and ph_baseline is not None else None

        # Prepare telemetry data
        telemetry_data = {
            "water_temperature": water_temp,
            "tds": tds if tds is not None else -1,
            "ph": ph if ph is not None else -1,
            "net_tds": net_tds if net_tds is not None else -1,
            "net_ph": net_ph if net_ph is not None else -1,
            "avg_temp_c": avg_temp,
            "avg_humidity": avg_humidity,
            "distance_cm": sensor_data["distance_cm"],
            "water_level_percent": water_level_percent,
            "tank_level": tank_level,
            "misting_pump_active": misting_pump_active,
            "tank_refill_active": tank_refill_active,
            "nutrient_pump_active": nutrient_pump_active,
            "mixing_pump_active": mixing_pump_active,
            "current_reading": sensor_data["current_reading"],
            "voltage_reading": sensor_data["voltage_reading"],
            "emergency_stop": emergency_stop,
            "manual_override": manual_override,
            "relay22_state": relay22_state,
            "relay23_state": relay23_state,
            "relay28_state": relay28_state,
            "relay29_state": relay29_state,
            "camera_enabled": CAMERA_ENABLED,
            "led_strip_tower1_active": should_led_strip_be_on(relay22_state),
            "led_strip_tower2_active": should_led_strip_be_on(relay23_state)
        }
        
        # Send data to cloud
        logging.info(telemetry_data)  # For debugging
        logging.debug(f"Telemetry data prepared: {telemetry_data}")
        send_to_thingsboard(telemetry_data)
        
        # Log system status periodically
        if current_time % 60000 < 100:  # Log every ~1 minute
            logging.info(
                f"System Status - "
                f"TDS: {tds:.1f} ppm | "
                f"pH: {ph:.1f} | "
                f"Water Temp: {water_temp:.1f}°C | "
                f"Air Temp: {avg_temp:.1f}°C | "
                f"Humidity: {avg_humidity:.1f}% | "
                f"Tank: {tank_level} | "
                f"Misting: {'ON' if misting_pump_active else 'OFF'}"
            )
        
        time.sleep(0.1)  # Main loop delay

#------------------------------------------------------------------------------
# Program Entry Point
#------------------------------------------------------------------------------
if __name__ == "__main__":
    try:
        if ser:
            logging.info("Starting hydroponic system controller")
            main()
        else:
            logging.error("Serial port not opened. Exiting...")
    except KeyboardInterrupt:
        logging.info("Program terminated by user")
    finally:
        # Cleanup
        if ser and ser.is_open:
            # Turn off all relays
            for relay in [22, 23, 26, 27, 30, 31, 32, 33, 35, 37]:
                send_command(f"RELAY:{relay},0")
            ser.close()
            logging.info("Serial port closed and all relays turned off")
        
        if CAMERA_ENABLED and cap.isOpened():
            cap.release()
            logging.info("Camera released")
        
        logging.info("System shutdown complete")
